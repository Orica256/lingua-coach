# ============================================================
# LinguaCoach 環境変数テンプレート
# ============================================================
# 使い方:
#   1. このファイルをコピーして .env.local を作成
#   2. 下記の各値を実際のキーに置き換え
#   3. .env.local は絶対に Git にコミットしない（.gitignore で除外済み）
#
# 注意:
#   - NEXT_PUBLIC_ プレフィックスがついた変数のみクライアントに露出します
#   - APIキーやサービスロールキーは絶対に NEXT_PUBLIC_ を付けないこと
# ============================================================

# ---------- Anthropic Claude API（サーバーサイドのみ） ----------
# 取得先: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 使用モデル（変更可）
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------- Supabase ----------
# 取得先: Supabase Dashboard → Settings → API
# anon key はクライアント露出OK（RLSで保護）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxx

# service_role key はサーバーサイドのみ（絶対に NEXT_PUBLIC_ を付けない）
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxx

# ---------- レート制限（Upstash Redis - 任意） ----------
# 取得先: https://console.upstash.com/
# 未設定の場合はメモリベースのレート制限にフォールバック
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- アプリ設定 ----------
# 本番URLは Vercel デプロイ後に設定
NEXT_PUBLIC_APP_URL=http://localhost:3000
